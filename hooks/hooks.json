        "hooks": [
            {
              "type": "command",
              "command": "node \"${PLUGIN_ROOT}/scripts/context-handoff.mjs\" hook",
              "commandWindows": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe -NoLogo -NoProfile -NonInteractive -Command node \"$env:PLUGIN_ROOT/scripts/context-handoff.mjs\" hook",
              "timeout": 10
